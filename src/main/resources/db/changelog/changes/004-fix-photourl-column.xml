<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">

    <changeSet id="004-fix-photourl-column" author="equipe-inf1013">
        <dropTable tableName="annoncephotos"/>
        <createTable tableName="annoncephotos">
            <column name="annonceid" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="photourl" type="TEXT"/>
        </createTable>
        <addForeignKeyConstraint
                baseTableName="annoncephotos"
                baseColumnNames="annonceid"
                referencedTableName="annonces"
                referencedColumnNames="id"
                constraintName="fk_annoncephotos_annonce"/>
    </changeSet>

</databaseChangeLog>