<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">

    <changeSet id="002-add-photos-table" author="oceane">
        <createTable tableName="annonce_photos">
            <column name="annonce_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_annonce_photos_annonce"
                             references="annonces(id)"
                             deleteCascade="true"/>
            </column>
            <column name="photo_url" type="TEXT">
                <constraints nullable="true"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>